{
  "name": "ops-hub",
  "private": true,
  "version": "0.1.0",
  "description": "AI Operations Hub — turn enquiries into assigned, traceable work.",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter ./apps/* dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ops-hub/db prisma:generate",
    "db:migrate": "pnpm --filter @ops-hub/db prisma:migrate",
    "db:seed": "pnpm --filter @ops-hub/db seed",
    "db:reset": "pnpm --filter @ops-hub/db prisma:reset"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20"
  }
}
