# Postgres
DATABASE_URL="postgresql://opshub:opshub@localhost:5432/opshub?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth (magic link)
AUTH_SECRET="change-me-long-random-string"
