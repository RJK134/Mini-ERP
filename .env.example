# Copy this file to .env and fill in real values.
# Nothing here is a real credential.

# Postgres (used by docker-compose)
POSTGRES_USER=opshub
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_ONLY
POSTGRES_DB=opshub
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth (magic link)
AUTH_SECRET=CHANGE_ME
AUTH_EMAIL_FROM="ops@example.com"

# Inbound email webhook (Postmark or SendGrid Parse)
INBOUND_WEBHOOK_SECRET=CHANGE_ME
INBOUND_PROVIDER=postmark

# Outbound email
OUTBOUND_API_KEY=CHANGE_ME
OUTBOUND_PROVIDER=postmark

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=CHANGE_ME

# Storage (MinIO defaults for local docker-compose)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME_LOCAL_ONLY
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET=ops-hub-attachments
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# Stripe (phase 5)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
