{
  "name": "@ops-hub/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums.ts"
  },
  "scripts": {
    "prisma:generate": "prisma generate",
